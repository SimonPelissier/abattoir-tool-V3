# Copy this file to .streamlit/secrets.toml and fill in your keys.
# DO NOT COMMIT secrets.toml to git — it's already in .gitignore.
#
# On Streamlit Cloud, paste these same lines into:
#   Dashboard → your app → Settings → Secrets

GEMINI_API_KEY = "paste-your-gemini-key-here"
SERPAPI_API_KEY = "paste-your-serpapi-key-here"
GOOGLE_PLACES_API_KEY = "paste-your-google-places-key-here"

# Optional override for the cache directory (defaults to ~/.osfl_slaughterhouse_cache).
# CACHE_DIR = "/tmp/osfl_cache"
